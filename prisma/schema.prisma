// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
// Datasource "db": MySQL database "alquilersagas" at "localhost:3307"

// Generador del cliente de Prisma para interactuar con la BD desde TypeScript
generator client {
  provider = "prisma-client-js"
}

// Configuración de la base de datos
datasource db {
  provider = "mysql"
}

model Usuarios {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String   // Se cifrará antes de guardarse
  role      Role     @default(CLIENT)
  rentals   Rental[]
  createdAt DateTime @default(now())
}

model Sagas {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  movies      Movie[]
}

model Peliculas {
  id          Int      @id @default(autoincrement())
  title       String
  releaseYear Int
  sagaId      Int?
  saga        Saga?    @relation(fields: [sagaId], references: [id], onDelete: SetNull)
  rentals     Rental[]
}

model Alquileres {
  id        Int      @id @default(autoincrement())
  userId    Int
  movieId   Int
  user      User     @relation(fields: [userId], references: [id])
  movie     Movie    @relation(fields: [movieId], references: [id])
  rentedAt  DateTime @default(now())
  expiresAt DateTime // Lógica de 30 días
}

enum Role {
  CLIENT
  MANAGER
  ADMIN
}