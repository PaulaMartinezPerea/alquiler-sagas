// Generador del cliente de Prisma para interactuar con la BD desde TypeScript
generator client {
  provider = "prisma-client-js"
}

// Configuración de la base de datos
datasource db {
  provider = "mysql"
}

model Usuarios {
  id        Int          @id @default(autoincrement())
  email     String       @unique
  password  String       // Se cifrará antes de guardarse
  role      Role         @default(CLIENT)
  rentals   Alquileres[] 
  createdAt DateTime     @default(now())
}

model Sagas {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  description String?
  movies      Peliculas[] 
}

model Peliculas {
  id          Int          @id @default(autoincrement())
  title       String
  releaseYear Int
  sagaId      Int?
  saga        Sagas?       @relation(fields: [sagaId], references: [id], onDelete: SetNull)
  rentals     Alquileres[] 
}

model Alquileres {
  id        Int       @id @default(autoincrement())
  userId    Int
  movieId   Int
  user      Usuarios  @relation(fields: [userId], references: [id])
  movie     Peliculas @relation(fields: [movieId], references: [id])
  rentedAt  DateTime  @default(now())
  expiresAt DateTime  // Lógica de 30 días
}

enum Role {
  CLIENT
  MANAGER
  ADMIN
}